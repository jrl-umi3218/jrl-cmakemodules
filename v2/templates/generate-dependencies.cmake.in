# Generated and temporary file - do not edit

cmake_minimum_required(VERSION 3.22)

include("${CMAKE_CURRENT_LIST_DIR}/imported-libraries.cmake")

message(DEBUG "[@PROJECT_NAME@::${component_name}] Generating dependencies.cmake")

# Check if the required variables are defined
if(NOT DEFINED all_exported_targets)
    message(
        FATAL_ERROR
        "all_exported_targets variable is not defined in @IMPORTED_LIBRARIES_TO_EXPORT_FILE@."
    )
endif()

if(NOT DEFINED all_interface_link_libraries)
    message(
        FATAL_ERROR
        "all_interface_link_libraries variable is not defined in @IMPORTED_LIBRARIES_TO_EXPORT_FILE@."
    )
endif()

if(NOT DEFINED package_dependencies_json_content)
    message(
        FATAL_ERROR
        "package_dependencies_json_content variable is not defined in @IMPORTED_LIBRARIES_TO_EXPORT_FILE@."
    )
endif()

# Parse the 'package_dependencies_json_content' JSON content
# NOTE: 'package_dependencies_json_content' can be defined but empty
# if no call to jrl_find_package() has been made in the project.
if(package_dependencies_json_content)
    string(
        JSON package_dependencies
        GET "${package_dependencies_json_content}"
        "package_dependencies"
    )
    string(JSON num_deps LENGTH "${package_dependencies}")
    math(EXPR max_idx "${num_deps} - 1")
endif()

set(fd "")
set(unknwon_libraries "")
set(missing_expected_dep_indices "")
foreach(ll IN LISTS all_interface_link_libraries)
    if(NOT ll)
        continue()
    endif()

    message(DEBUG "    Processing imported library: ${ll}")

    # Filter the libraries present the all_exported_targets.
    if(ll IN_LIST all_exported_targets)
        message(DEBUG "        ==> Target ${ll} is part of the export component, skipping.")
        continue()
    endif()

    if(NOT package_dependencies_json_content)
        message(DEBUG "        ==> The package_dependencies_json content is empty, skipping.")
        list(APPEND unknwon_libraries ${ll})
        continue()
    endif()

    # Find the corresponding package dependency JSON info
    # Note that there might be several candidates.
    # (e.g. if multiple jrl_find_package() calls for the same package with different arguments).
    set(candidate_indices "")
    foreach(idx RANGE ${max_idx})
        string(JSON dep_i_json GET "${package_dependencies}" ${idx})
        string(JSON package_targets GET "${dep_i_json}" "package_targets")
        if("${ll}" IN_LIST package_targets)
            list(APPEND candidate_indices ${idx})
        endif()
    endforeach()

    set(package_json "")
    set(package_dep_idx "")

    # For now we take the *first* candidate in the list.
    foreach(candidate_idx IN LISTS candidate_indices)
        list(GET candidate_indices 0 candidate_idx)
        string(JSON package_json GET "${package_dependencies}" ${candidate_idx})
        set(package_dep_idx "${candidate_idx}")
        break()
    endforeach()

    if(NOT package_json)
        message(
            DEBUG
            "      ==> Could not find package dependency information for imported target: ${ll}"
        )
        list(APPEND unknwon_libraries ${ll})
        continue()
    endif()

    # Parse the package JSON info
    string(JSON package_name GET "${package_json}" "package_name")
    string(JSON find_package_args GET "${package_json}" "find_package_args")
    string(JSON package_targets GET "${package_json}" "package_targets")
    string(JSON expected_targets GET "${package_json}" "expected_targets")
    string(JSON module_file GET "${package_json}" "module_file")

    # Collect missing EXPECTED_TARGETS by package dependency entry and emit one warning per entry.
    set(is_expected FALSE)
    if(expected_targets AND "${ll}" IN_LIST expected_targets)
        set(is_expected TRUE)
    endif()

    if(NOT is_expected)
        # Save the index of the package that has a missing entry in EXPECTED_TARGETS.
        if(NOT "${package_dep_idx}" IN_LIST missing_expected_dep_indices)
            list(APPEND missing_expected_dep_indices "${package_dep_idx}")
        endif()

        # Save the missing target in a list specific to the package dependency entry.
        if(NOT "${ll}" IN_LIST missing_expected_targets_${package_dep_idx})
            list(APPEND missing_expected_targets_${package_dep_idx} "${ll}")
        endif()
    endif()

    if(NOT fd)
        set(fd "include(CMakeFindDependencyMacro)\n\n")
    endif()

    # Handling if package is using a custom module
    if(module_file)
        string(
            APPEND fd
            "list(APPEND CMAKE_MODULE_PATH \${CMAKE_CURRENT_LIST_DIR}/find-modules/${package_name})\n\n"
        )
        # Use the undocumented file(INSTALL) command to install files in a script.
        # This is the same syntax as the generated cmake_install.cmake file.
        if(IS_ABSOLUTE @INSTALL_DESTINATION@)
            file(
                INSTALL
                DESTINATION @INSTALL_DESTINATION@/find-modules/${package_name}
                TYPE
                FILE
                FILES
                ${module_file}
            )
        else()
            file(
                INSTALL
                DESTINATION
                    ${CMAKE_INSTALL_PREFIX}/@INSTALL_DESTINATION@/find-modules/${package_name}
                TYPE
                FILE
                FILES
                ${module_file}
            )
        endif()
    endif()

    string(REPLACE ";" " " find_package_args "${find_package_args}")

    # Handling find_dependency logic
    if(NOT package_targets)
        string(APPEND fd "find_dependency(${find_package_args})\n")
    else()
        string(APPEND fd "if(NOT TARGET ${ll})\n")
        string(
            APPEND fd
            "    message(DEBUG \"            ==> Executing find_dependency(${find_package_args})\")\n"
        )
        string(APPEND fd "    find_dependency(${find_package_args})\n")
        string(APPEND fd "else()\n")
        string(
            APPEND fd
            "    message(DEBUG \"            ==> Target ${ll} already exists, skipping find_dependency(${find_package_args})\")\n"
        )
        string(APPEND fd "endif()\n\n")
    endif()
endforeach()

# Emit warnings for missing EXPECTED_TARGETS entries, one per package dependency entry.
foreach(dep_idx IN LISTS missing_expected_dep_indices)
    # get the JSON entry of the dependency
    string(JSON package_json GET "${package_dependencies}" ${dep_idx})
    string(JSON package_name GET "${package_json}" "package_name")
    string(JSON find_package_args GET "${package_json}" "find_package_args")
    string(JSON expected_targets GET "${package_json}" "expected_targets")

    # Build the list of EXPECTED_TARGETS
    set(missing_targets "${missing_expected_targets_${dep_idx}}")
    set(suggested_expected_targets "${expected_targets}")
    list(APPEND suggested_expected_targets "${missing_targets}")
    list(REMOVE_DUPLICATES suggested_expected_targets)

    string(REPLACE ";" " " find_package_args_pp "${find_package_args}")
    string(REPLACE ";" " " suggested_expected_targets_pp "${suggested_expected_targets}")
    string(REPLACE ";" "' '" missing_targets_pp "${missing_targets}")

    message(
        AUTHOR_WARNING
        "
[@PROJECT_NAME@] Targets '${missing_targets_pp}' from package '${package_name}' are referenced in the INTERFACE_LINK_LIBRARIES of component '${component_name}', but are not declared in EXPECTED_TARGETS.
To support superbuild configurations, please modify the call:
    jrl_find_package(${find_package_args_pp})
To:
    jrl_find_package(${find_package_args_pp} EXPECTED_TARGETS ${suggested_expected_targets_pp})
            "
    )
endforeach()

if(unknwon_libraries)
    message(
        AUTHOR_WARNING
        "[@PROJECT_NAME@] The following dependencies/libraries were found in the 'INTERFACE_LINK_LIBRARIES' of the export component, but have not been imported via jrl_find_package():
'${unknwon_libraries}'
This means we cannot generate the appropriate 'find_dependency()' call in the export component's dependencies.cmake file, so that consumers can import them transitively.
Please make sure to call jrl_find_package() to import these targets, or jrl_export_dependency() to explicitly mark them as part of the export component (not recommended).
        "
    )
endif()

string(PREPEND fd "# Generated file - do not edit\n")

# Read existing file and compare
if(EXISTS ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake)
    file(READ ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake existing_fd)
else()
    set(existing_fd "")
endif()

if(fd STREQUAL existing_fd)
    message(
        DEBUG
        "       Same content generated for ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake, not overwriting."
    )
else()
    message(DEBUG "       Writing ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake")
    file(WRITE ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake "${fd}")
endif()

# Use the undocumented file(INSTALL) command to install files in a script.
# This is the same syntax as the generated cmake_install.cmake file.
if(IS_ABSOLUTE @INSTALL_DESTINATION@)
    file(
        INSTALL
        DESTINATION @INSTALL_DESTINATION@
        TYPE
        FILE
        FILES
        ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake
    )
else()
    file(
        INSTALL
        DESTINATION ${CMAKE_INSTALL_PREFIX}/@INSTALL_DESTINATION@
        TYPE
        FILE
        FILES
        ${CMAKE_CURRENT_LIST_DIR}/dependencies.cmake
    )
endif()
